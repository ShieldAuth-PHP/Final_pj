{
  "manifest_version": 3,
  "name": "YARA Malware Detector",
  "version": "1.0",
  "description": "Chrome extension that scans downloaded files and web pages using YARA rules.",
  "permissions": [
    "downloads",
    "notifications",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentscript.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/alert.png",
      "128": "icons/vaccine.png"
    }
  },
  "icons": {
    "48": "icons/alert.png",
    "128": "icons/vaccine.png"
  }
}
